// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String        @id
  email           String        @unique
  location        String?
  experienceLevel String?
  targetRole      String?
  intentState     String        @default("exploratory")
  skills          UserSkill[]
  skillGaps       SkillGapReport[]
  applications    Application[]
  matchSignals    UserMatchSignal[]
  savedJobs       SavedJob[]
  resume          Resume?
  workHistory     WorkHistory[]
  projects        Project[]
  createdAt       DateTime      @default(now())
}

model UserSkill {
  id     String @id @default(cuid())
  name   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model Resume {
  id         String    @id @default(cuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  rawText    String?
  uploadedAt DateTime  @default(now())
  parsedAt   DateTime?
}

model AIJobScore {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  score     Int      // 0–100
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
}

model WorkHistory {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  title     String
  startDate DateTime?
  endDate   DateTime?
  summary   String?
  order     Int       @default(0)
}

model Project {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  url         String?
  techStack   String[]
  startDate   DateTime?
  endDate     DateTime? // null = ongoing
  order       Int       @default(0)
}

// prisma/schema.prisma

model Job {
  id              String   @id @default(cuid())
  // Deduplication key: "{source}:{externalId}"
  sourceJobId     String   @unique
  
  // Core fields
  title           String
  company         String
  companySlug     String   // normalized, e.g. "stripe" — for grouping
  location        String?
  remote          Boolean  @default(false)
  description     String   // cleaned plain text
  descriptionHtml String?  // raw HTML, kept for re-processing
  applyUrl        String
  postedAt        DateTime?
  
  // Classification
  employmentType  String?  // full_time | part_time | contract | internship
  seniorityLevel  String?  // intern | junior | mid | senior | staff | principal | exec
  department      String?
  
  // Extracted signal (populated async by matching pipeline)
  extractedSkills String[] @default([])
  
  // Source metadata
  source          String   // greenhouse | lever | ashby | workday | smartrecruiters
  rawData         Json?    // raw ATS response, useful for debugging + reprocessing
  
  // Lifecycle
  isActive        Boolean  @default(true)
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now()) // updated every ingest run
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  applications    Application[]
  savedBy         SavedJob[]
  companyId   String?
  companyRef  Company? @relation(fields: [companyId], references: [id])

  @@index([source])
  @@index([companySlug])
  @@index([isActive])
  @@index([seniorityLevel])
  @@index([remote])
  // Composite for the matching query hot path
  @@index([isActive, remote, seniorityLevel])
}

model IngestionRun {
  id          String   @id @default(cuid())
  source      String   // "greenhouse:stripe" or "lever:notion"
  status      String   // running | success | partial | failed
  jobsFetched Int      @default(0)
  jobsUpserted Int     @default(0)
  jobsSkipped Int      @default(0) // non-US filtered out
  errors      Json?    // array of error messages
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  @@index([source])
  @@index([startedAt])
}

model Company {
  id              String    @id @default(cuid())
  name            String    @unique
  logoUrl         String?
  website         String?
  isActive        Boolean   @default(true)

  greenhouseSlug  String?   @unique
  leverSite       String?   @unique
  ashbyBoardId    String?   @unique
  workdayTenant   String?
  workdayInstance String?   // "wd1" | "wd2" | "wd3" | "wd5"
  workdaySiteName String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  jobs            Job[]
}

model Application {
  id            String    @id @default(cuid())
  jobId         String?
  userId        String
  company       String
  jobTitle      String
  applyUrl      String?
  status        String    @default("applied")
  outcomeAt     DateTime?
  notes         String?
  appliedAt     DateTime  @default(now())
  interviewDate DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job?      @relation(fields: [jobId], references: [id])
}

// Stores learned per-user signals derived from outcome history
// Recomputed nightly or after each outcome update
model UserMatchSignal {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company-level signal
  companySlug     String?
  companyBoost    Float    @default(0) // +0–10

  // Skill-level signal
  skillName       String?
  skillWeight     Float    @default(1.0) // multiplier on skill score

  // Suppression signal — hashed fingerprint of a job's title+seniority+department
  jobFingerprint  String?
  suppressed      Boolean  @default(false)

  signalType      String   // "company_boost" | "skill_weight" | "suppression"
  confidence      Float    @default(1.0) // 0–1, degrades over time
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([userId, signalType, companySlug, skillName, jobFingerprint])
  @@index([userId, signalType])
}

// Skill gap report — generated async, read by the UI
model SkillGapReport {
  id          String   @id @default(cuid())
  userId      String   @unique
  gaps        Json
  explanation String?  // ← add this
  generatedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
}

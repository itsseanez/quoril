// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id
  email        String        @unique
  name         String?
  location     String?
  experienceLevel String?    // "entry" | "mid" | "senior"
  targetRole   String?
  intentState  String        @default("exploratory") // "locked" | "hybrid" | "exploratory"
  skills       UserSkill[]
  applications Application[]
  createdAt    DateTime      @default(now())
}

model UserSkill {
  id     String @id @default(cuid())
  name   String
  level  String // "beginner" | "intermediate" | "advanced"
  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model Job {
  id                     String   @id @default(cuid())
  title                  String
  company                String
  location               String?
  remote                 Boolean  @default(false)
  description            String
  applyUrl               String
  source                 String   // "greenhouse" | "lever"
  companySize            String?
  sourceJobId            String   @unique
  createdAt              DateTime @default(now())
}

model Application {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  status    String   @default("applied") // "applied" | "interviewing" | "rejected" | "offer"
  notes     String?
  appliedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}